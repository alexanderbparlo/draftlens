# ── Required ────────────────────────────────────────────────────────────────
# Anthropic API key — server-side only. Never expose with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# ── Optional (production rate limiting) ─────────────────────────────────────
# When unset, rate limiting falls back to an in-memory store (per-instance,
# resets on restart — fine for local dev, not safe for prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Public ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=DraftLens
NEXT_PUBLIC_APP_VERSION=0.1.0
